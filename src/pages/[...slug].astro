---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getPages, rewriteContentUrls } from '@phantomwp/wordpress';

export async function getStaticPaths() {
  const allPages = await getPages({ perPage: 50 });
  return allPages.map(page => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: Awaited<ReturnType<typeof getPages>>[number] };
const title = page.title?.rendered || '';
const content = rewriteContentUrls(page.content?.rendered || '');
const description = (page.excerpt?.rendered || '').replace(/<[^>]+>/g, '').trim();

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: title },
];
---

<BaseLayout title={title} description={description}>
  <Header />
  <main id="main-content" class="page-page">
    <article class="page-article">
      <div class="container">
        <Breadcrumbs items={breadcrumbItems} />
        <header class="page-header">
          <h1 class="page-title" set:html={title} />
        </header>
        <div class="content prose" set:html={content} />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
.page-page {
  background-color: var(--color-surface);
}

.page-article {
  padding-block: var(--space-2xl, 3rem) calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem));
}

.container {
  max-width: var(--container-3xl, 48rem);
  margin-inline: auto;
  padding-inline: clamp(var(--space-md, 1rem), 4vw, var(--space-xl, 2rem));
}

.page-header {
  margin-bottom: var(--space-2xl, 3rem);
  padding-bottom: var(--space-xl, 2rem);
  border-bottom: 1px solid var(--color-outline);
}

.page-title {
  font-size: clamp(var(--text-3xl, 1.875rem), 5vw, var(--text-4xl, 2.25rem));
  font-weight: var(--font-weight-bold, 700);
  color: var(--color-content);
}

.content {
  font-size: var(--text-base, 1rem);
  line-height: var(--leading-relaxed, 1.75);
  color: var(--color-content);
}
</style>
