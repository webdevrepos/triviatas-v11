---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout title="404 - Page Not Found">
    <Header />
    <main id="main-content" class="error-page">
        <section class="section">
            <div class="container">
                <div class="content">
                    <h1 class="code">404</h1>
                    <h2 class="heading">Page Not Found</h2>
                    <p class="message">The page you're looking for doesn't exist or has been moved.</p>
                    <a href="/" class="btn">Go Back Home</a>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</BaseLayout>

<style>
/* Error/404 Page */
.error-page { background-color: var(--color-surface); }
.section { padding-block: calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem)); min-height: 60vh; display: flex; align-items: center; }
.container { max-width: var(--container-7xl, 80rem); margin-inline: auto; padding-inline: clamp(var(--space-md, 1rem), 4vw, var(--space-xl, 2rem)); }
.content { text-align: center; margin-inline: auto; }
.code { font-size: clamp(6rem, 18vw, 10rem); font-weight: var(--font-weight-bold, 700); line-height: 1; margin-bottom: var(--space-md, 1rem); background: linear-gradient(to right, var(--color-primary), var(--color-accent, var(--color-primary-light))); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.heading { font-size: clamp(var(--text-2xl, 1.5rem), 4vw, var(--text-3xl, 1.875rem)); font-weight: var(--font-weight-bold, 700); margin-bottom: var(--space-md, 1rem); color: var(--color-content); }
.message { color: var(--color-content-light); font-size: var(--text-lg, 1.125rem); margin-bottom: var(--space-xl, 2rem); }
.btn { display: inline-block; background-color: var(--color-primary); color: white; font-weight: var(--font-weight-semibold, 600); padding: var(--space-sm, 0.5rem) var(--space-lg, 1.5rem); border-radius: var(--radius-lg, 0.5rem); text-decoration: none; cursor: pointer; transition: background-color var(--duration-fast, 150ms) var(--ease-out, cubic-bezier(0, 0, 0.2, 1)); }
.btn:hover { background-color: var(--color-primary-dark); }

</style>
