---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import BlogGrid from '@/components/BlogGrid.astro';
import Feather from '@lucide/astro/icons/feather';
import { getAllPosts } from '@phantomwp/wordpress';

const allPosts = await getAllPosts();

let siteTitle = 'Triviatas Blog';
let siteSubtitle = 'Technologie- und Lifestyle-News';
try {
  const res = await fetch('https://panel.triviatas.de/wp-json/custom/v1/site-options');
  const data = await res.json();
  if (data?.homepage_text_1) siteTitle = data.homepage_text_1;
  if (data?.homepage_text_2) siteSubtitle = data.homepage_text_2;
} catch {}
---

<BaseLayout title="Home">
  <Header />
  <main id="main-content">
    <section class="hero-section">
      <div class="hero-container">
        <div class="hero-icon-wrap">
          <Feather class="hero-icon" />
        </div>
        <h1 class="hero-title">{siteTitle}</h1>
        <p class="hero-subtitle">{siteSubtitle}</p>
      </div>
    </section>
    <BlogGrid posts={allPosts} />
  </main>
  <Footer />
</BaseLayout>

<style>
  main {
    background-color: var(--color-surface);
  }

  .hero-section {
    padding-top: calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem));
    padding-bottom: var(--space-lg, 1.5rem);
  }

  .hero-container {
    max-width: var(--container-7xl, 80rem);
    margin-inline: auto;
    padding-inline: clamp(var(--space-md, 1rem), 4vw, var(--space-xl, 2rem));
    text-align: center;
  }

  .hero-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: var(--space-lg, 1.5rem);
    border-radius: var(--radius-xl, 0.75rem);
    background-color: color-mix(in srgb, var(--color-primary) 10%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, var(--color-outline));
  }

  .hero-icon {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--color-primary);
  }

  .hero-title {
    margin-bottom: var(--space-md, 1rem);
    font-size: clamp(var(--text-3xl, 1.875rem), 5vw, var(--text-4xl, 2.25rem));
    font-weight: var(--font-weight-bold, 700);
    color: var(--color-content);
  }

  .hero-subtitle {
    font-size: var(--text-lg, 1.125rem);
    color: var(--color-content-light);
    max-width: var(--container-3xl, 48rem);
    margin-inline: auto;
  }
</style>
