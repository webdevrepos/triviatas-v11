---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import BlogGrid from '@/components/BlogGrid.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Pagination from '@/components/Pagination.astro';
import { getCategoryBySlug, getPosts } from '@phantomwp/wordpress';

export async function getStaticPaths() {
  const { getCategories } = await import('@phantomwp/wordpress');
  const allCategories = await getCategories();

  const pageSize = 12;
  const paths: {
    params: { path: string | undefined };
    props: {
      posts: Awaited<ReturnType<typeof getPosts>>;
      categoryName: string;
      categorySlug: string;
      currentPage: number;
      totalPages: number;
    };
  }[] = [];

  for (const cat of allCategories) {
    if (cat.name === 'Uncategorized' && cat.count === 0) continue;
    if (cat.count === 0) continue;

    const totalPages = Math.max(1, Math.ceil(cat.count / pageSize));

    for (let i = 0; i < totalPages; i++) {
      const pageNum = i + 1;
      const slug = pageNum === 1 ? cat.slug : `${cat.slug}/${pageNum}`;
      const catPosts = await getPosts({ categories: [cat.id], perPage: pageSize, page: pageNum });

      paths.push({
        params: { path: slug },
        props: {
          posts: catPosts,
          categoryName: cat.name,
          categorySlug: cat.slug,
          currentPage: pageNum,
          totalPages,
        },
      });
    }
  }

  return paths;
}

const { path } = Astro.params;
const segments = (path || '').split('/');
const currentCategorySlug = segments[0] || '';

const { posts, categoryName, categorySlug, currentPage, totalPages } = Astro.props;
const baseUrl = `/category/${categorySlug}`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: categoryName },
];
---

<BaseLayout title={categoryName} description={`Browse all posts in the ${categoryName} category.`}>
  <Header />
  <main id="main-content">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} class="cat-breadcrumbs" />
      <BlogGrid posts={posts} title={categoryName} />
      {totalPages > 1 && (
        <div class="pagination-wrap">
          <Pagination {currentPage} {totalPages} baseUrl={baseUrl} />
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
main {
  background-color: var(--color-surface);
}

.container {
  max-width: var(--container-7xl, 80rem);
  margin-inline: auto;
  padding-inline: clamp(var(--space-md, 1rem), 4vw, var(--space-xl, 2rem));
}

.cat-breadcrumbs {
  padding-top: calc(var(--space-xl, 2rem) + var(--space-md, 1rem));
  margin-bottom: 0;
}

.pagination-wrap {
  padding-bottom: calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem));
}
</style>
