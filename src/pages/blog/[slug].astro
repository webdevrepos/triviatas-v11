---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PostPlaceholder from '@/components/PostPlaceholder.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const paths = [];

  for (const post of posts) {
    const { Content } = await render(post);
    paths.push({
      params: { slug: post.id },
      props: { Content, data: post.data, slug: post.id },
    });
  }

  return paths;
}

interface PostData {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  author: string;
}

const { Content, data, slug } = Astro.props;
const { title, description, pubDate, category, author } = data as unknown as PostData;

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === category && p.id !== slug && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: category, href: `/category/${category.toLowerCase()}` },
  { label: title },
];
---

<BaseLayout title={title} description={description}>
  <Header />
  <main id="main-content" class="post-page">
    <article class="post">
      <PostPlaceholder title={title} category={category} class="post-image" />
      <div class="container">
        <Breadcrumbs items={breadcrumbItems} />
        <header class="post-header">
          <div class="meta">
            <a href={`/category/${category.toLowerCase()}`} class="category">{category}</a>
            <time class="date" datetime={pubDate instanceof Date ? pubDate.toISOString() : String(pubDate)}>
              {pubDate instanceof Date
                ? pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
                : String(pubDate)}
            </time>
          </div>
          <h1 class="title">{title}</h1>
          <p class="desc">{description}</p>
          <div class="author-line">
            By <span class="author">{author}</span>
          </div>
        </header>
        <div class="content prose">
          <Content />
        </div>
      </div>

      {relatedPosts.length > 0 && (
        <section class="related-section">
          <div class="container">
            <h2 class="related-heading">Related Posts</h2>
            <div class="related-grid">
              {relatedPosts.map(post => <BlogCard post={post} />)}
            </div>
          </div>
        </section>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
.post-page {
  background-color: var(--color-surface);
}

.post {
  padding-block: 0 0;
}

.post-image {
  width: 100%;
  aspect-ratio: 1200 / 420;
  overflow: hidden;
}

.container {
  max-width: var(--container-3xl, 48rem);
  margin-inline: auto;
  padding-inline: clamp(var(--space-md, 1rem), 4vw, var(--space-xl, 2rem));
  padding-top: var(--space-2xl, 3rem);
  padding-bottom: calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem));
}

.post-header {
  margin-bottom: var(--space-2xl, 3rem);
  padding-bottom: var(--space-xl, 2rem);
  border-bottom: 1px solid var(--color-outline);
}

.meta {
  display: flex;
  align-items: center;
  gap: var(--space-md, 1rem);
  margin-bottom: var(--space-lg, 1.5rem);
}

.category {
  font-size: var(--text-xs, 0.75rem);
  font-weight: var(--font-weight-semibold, 600);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-on-primary);
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-full, 9999px);
  background-color: var(--color-primary);
  text-decoration: none;
  transition: background-color var(--duration-fast, 150ms) var(--ease-out);
}

.category:hover {
  background-color: var(--color-primary-dark);
}

.date {
  font-size: var(--text-sm, 0.875rem);
  color: var(--color-content-lighter);
}

.title {
  margin-bottom: var(--space-md, 1rem);
  font-size: clamp(var(--text-3xl, 1.875rem), 5vw, var(--text-4xl, 2.25rem));
  font-weight: var(--font-weight-bold, 700);
  line-height: var(--leading-tight, 1.2);
  color: var(--color-content);
}

.desc {
  font-size: var(--text-lg, 1.125rem);
  line-height: var(--leading-relaxed, 1.65);
  color: var(--color-content-light);
  margin-bottom: var(--space-md, 1rem);
}

.author-line {
  font-size: var(--text-sm, 0.875rem);
  color: var(--color-content-lighter);
}

.author {
  font-weight: var(--font-weight-semibold, 600);
  color: var(--color-content);
}

.content {
  font-size: var(--text-base, 1rem);
  line-height: var(--leading-relaxed, 1.75);
  color: var(--color-content);
}

.related-section {
  background-color: var(--color-surface-alt);
  padding-block: var(--space-2xl, 3rem);
}

.related-section .container {
  max-width: var(--container-7xl, 80rem);
  padding-top: 0;
  padding-bottom: 0;
}

.related-heading {
  margin-bottom: var(--space-xl, 2rem);
  font-size: var(--text-2xl, 1.5rem);
  font-weight: var(--font-weight-bold, 700);
  color: var(--color-content);
  text-align: center;
}

.related-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-lg, 1.5rem);
}

@media (min-width: 640px) {
  .related-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .related-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>
