---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getPost, getPosts, getPostCategories, getAuthor, rewriteContentUrls, formatDate } from '@phantomwp/wordpress';

export async function getStaticPaths() {
  const allPosts = await getPosts({ perPage: 100 });
  return allPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: NonNullable<Awaited<ReturnType<typeof getPost>>> };
const title = post.title?.rendered || '';
const content = rewriteContentUrls(post.content?.rendered || '');
const description = (post.excerpt?.rendered || '').replace(/<[^>]+>/g, '').trim();
const date = formatDate(post.date);
const categories = getPostCategories(post);
const category = categories[0]?.name || 'Uncategorized';
const categorySlug = categories[0]?.slug || '';
const author = getAuthor(post)?.name || 'Triviatas';

const categoryId = categories[0]?.id;
const relatedPosts = categoryId
  ? (await getPosts({ categories: [categoryId], perPage: 3 })).filter(p => p.id !== post.id).slice(0, 3)
  : [];

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  ...(categorySlug ? [{ label: category, href: `/category/${categorySlug}` }] : []),
  { label: title },
];
---

<BaseLayout title={title} description={description}>
  <Header />
  <main id="main-content" class="post-page">
    <article class="post">
      <div class="container">
        <Breadcrumbs items={breadcrumbItems} />
        <header class="post-header">
          <div class="meta">
            {categorySlug && (
              <a href={`/category/${categorySlug}`} class="category">{category}</a>
            )}
            <time class="date" datetime={post.date}>{date}</time>
          </div>
          <h1 class="title" set:html={title} />
          <div class="author-line">
            By <span class="author">{author}</span>
          </div>
        </header>
        <div class="content prose" set:html={content} />
      </div>

      {relatedPosts.length > 0 && (
        <section class="related-section">
          <div class="container">
            <h2 class="related-heading">Weitere Publikationen</h2>
            <div class="related-grid">
              {relatedPosts.map(p => <BlogCard post={p} />)}
            </div>
          </div>
        </section>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
.post-page {
  background-color: var(--color-surface);
}

.post {
  padding-block: 0 0;
}

.container {
  max-width: var(--container-3xl, 48rem);
  margin-inline: auto;
  padding-inline: clamp(var(--space-md, 1rem), 4vw, var(--space-xl, 2rem));
  padding-top: calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem));
  padding-bottom: calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem));
}

.post-header {
  margin-bottom: var(--space-2xl, 3rem);
  padding-bottom: var(--space-xl, 2rem);
  border-bottom: 1px solid var(--color-outline);
}

.meta {
  display: flex;
  align-items: center;
  gap: var(--space-md, 1rem);
  margin-bottom: var(--space-lg, 1.5rem);
}

.category {
  font-size: var(--text-xs, 0.75rem);
  font-weight: var(--font-weight-semibold, 600);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-on-primary);
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-full, 9999px);
  background-color: var(--color-primary);
  text-decoration: none;
  transition: background-color var(--duration-fast, 150ms) var(--ease-out);
}

.category:hover {
  background-color: var(--color-primary-dark);
}

.date {
  font-size: var(--text-sm, 0.875rem);
  color: var(--color-content-lighter);
}

.title {
  margin-bottom: var(--space-md, 1rem);
  font-size: clamp(var(--text-3xl, 1.875rem), 5vw, var(--text-4xl, 2.25rem));
  font-weight: var(--font-weight-bold, 700);
  line-height: var(--leading-tight, 1.2);
  color: var(--color-content);
}

.author-line {
  font-size: var(--text-sm, 0.875rem);
  color: var(--color-content-lighter);
}

.author {
  font-weight: var(--font-weight-semibold, 600);
  color: var(--color-content);
}

.content {
  font-size: var(--text-base, 1rem);
  line-height: var(--leading-relaxed, 1.75);
  color: var(--color-content);
}

.related-section {
  background-color: var(--color-surface-alt);
  padding-block: var(--space-2xl, 3rem);
}

.related-section .container {
  max-width: var(--container-7xl, 80rem);
  padding-top: 0;
  padding-bottom: 0;
}

.related-heading {
  margin-bottom: var(--space-xl, 2rem);
  font-size: var(--text-2xl, 1.5rem);
  font-weight: var(--font-weight-bold, 700);
  color: var(--color-content);
  text-align: center;
}

.related-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-lg, 1.5rem);
}

@media (min-width: 640px) {
  .related-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .related-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>
