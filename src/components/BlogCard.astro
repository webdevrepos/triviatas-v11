---
import type { WPPost } from '@phantomwp/wordpress';
import { getPostCategories, getAuthor, stripHtml, formatDate } from '@phantomwp/wordpress';

interface Props {
  post: WPPost;
}

function decodeEntities(text: string): string {
  const map: Record<string, string> = {
    '&amp;': '&', '&lt;': '<', '&gt;': '>', '&quot;': '"',
    '&#x27;': "'", '&#x2F;': '/', '&nbsp;': '\u00A0',
    '&hellip;': '\u2026', '&ndash;': '\u2013', '&mdash;': '\u2014',
    '&shy;': '\u00AD', '&copy;': '\u00A9', '&reg;': '\u00AE',
    '&euro;': '\u20AC', '&pound;': '\u00A3', '&sect;': '\u00A7',
  };
  let result = text.replace(/&#(\d+);/g, (_, c) => String.fromCharCode(parseInt(c, 10)));
  for (const [entity, char] of Object.entries(map)) {
    result = result.split(entity).join(char);
  }
  return result;
}

const { post } = Astro.props;
const title = post.title?.rendered || '';
const description = decodeEntities(stripHtml(post.excerpt?.rendered || '').trim());
const date = formatDate(post.date);
const categories = getPostCategories(post);
const category = categories[0]?.name || 'Uncategorized';
const author = getAuthor(post)?.name || 'Triviatas';
const postSlug = post.slug;
---

<article class="card">
  <a href={`/blog/${postSlug}`} class="link">
    <div class="body">
      <div class="meta">
        {categories.length > 0 && (
          <span class="category">{category}</span>
        )}
        <time class="date" datetime={post.date}>{date}</time>
      </div>
      <h2 class="title" set:html={title} />
      <p class="desc">{description}</p>
      <div class="footer-meta">
        <span class="author">{author}</span>
      </div>
    </div>
  </a>
</article>

<style>
.card {
  position: relative;
  border: 1px solid var(--color-outline);
  border-radius: var(--radius-xl, 0.75rem);
  background-color: var(--color-surface);
  transition:
    transform var(--duration-fast, 150ms) var(--ease-out),
    box-shadow var(--duration-fast, 150ms) var(--ease-out);
}

.card::before {
  content: '';
  display: block;
  height: 4px;
  background: linear-gradient(to right, var(--color-primary), var(--color-primary-dark));
  border-radius: var(--radius-xl, 0.75rem) var(--radius-xl, 0.75rem) 0 0;
}

.card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

.link {
  display: block;
  text-decoration: none;
  color: inherit;
  height: 100%;
}

.body {
  padding: var(--space-xl, 2rem);
  display: flex;
  flex-direction: column;
  height: 100%;
}

.meta {
  display: flex;
  align-items: center;
  gap: var(--space-md, 1rem);
  margin-bottom: var(--space-md, 1rem);
}

.category {
  font-size: var(--text-xs, 0.75rem);
  font-weight: var(--font-weight-semibold, 600);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-primary);
  padding: 0.25rem 0.625rem;
  border-radius: var(--radius-full, 9999px);
  background-color: color-mix(in srgb, var(--color-primary) 10%, var(--color-surface));
}

.date {
  font-size: var(--text-sm, 0.875rem);
  color: var(--color-content-lighter);
}

.title {
  margin-bottom: var(--space-sm, 0.5rem);
  font-size: var(--text-xl, 1.25rem);
  font-weight: var(--font-weight-bold, 700);
  line-height: var(--leading-tight, 1.3);
  color: var(--color-content);
  transition: color var(--duration-fast, 150ms) var(--ease-out);
}

.card:hover .title {
  color: var(--color-primary);
}

.desc {
  margin-bottom: var(--space-lg, 1.5rem);
  font-size: var(--text-sm, 0.875rem);
  line-height: var(--leading-relaxed, 1.65);
  color: var(--color-content-light);
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.footer-meta {
  display: flex;
  align-items: center;
  gap: var(--space-sm, 0.5rem);
  padding-top: var(--space-md, 1rem);
  border-top: 1px solid var(--color-outline-light);
}

.author {
  font-size: var(--text-sm, 0.875rem);
  color: var(--color-content-lighter);
}
</style>
