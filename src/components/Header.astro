---
import MainMenu from './menus/MainMenu.astro';
import logoImage from '@/media/triviatas-logo.png';

interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<header class:list={["header", className]}>
    <div class="container">
        <div class="inner">
            <a href="/" class="brand" aria-label="Triviatas">
                <img src={logoImage.src} alt="Triviatas" class="logo-img" />
            </a>
            <MainMenu />
        </div>
    </div>
</header>

<style>
.header {
    position: sticky;
    top: 0;
    z-index: 40;
    width: 100%;
    border-bottom: 1px solid var(--color-outline);
    background-color: color-mix(in srgb, var(--color-surface) 85%, transparent);
    backdrop-filter: blur(8px);
}

.container {
    max-width: var(--container-7xl, 80rem);
    margin-inline: auto;
    padding-inline: clamp(var(--space-md, 1rem), 4vw, var(--space-xl, 2rem));
}

.inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
}

.brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    line-height: 0;
}

.brand:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm, 0.25rem);
}

.logo-img {
    display: block;
    height: 2.5rem;
    width: auto;
}
</style>
