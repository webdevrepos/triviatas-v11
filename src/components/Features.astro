---
import Feature from './Feature.astro';
import Sparkles from '@lucide/astro/icons/sparkles';
import ArrowRight from '@lucide/astro/icons/arrow-right';

const features = [
    {
        title: "Content Management",
        description: "Easily manage your content with Markdown and MDX support. Write in your favorite format with full flexibility.",
        iconName: "FileText",
        badge: "Markdown & MDX"
    },
    {
        title: "Modern Styling",
        description: "Built with Custom CSS. Customize colors, spacing, and create beautiful designs with ease.",
        iconName: "Palette",
        badge: "Custom CSS"
    },
    {
        title: "Blazing Performance",
        description: "Zero JavaScript by default. Ship minimal code, load instantly, and rank higher in search results.",
        iconName: "Zap",
        badge: "100/100 Lighthouse"
    },
    {
        title: "Component Library",
        description: "Pre-built, customizable components ready to use. Headers, footers, cards, and more included.",
        iconName: "LayoutGrid",
        badge: "Plug & Play"
    },
    {
        title: "SEO Optimized",
        description: "Built-in SEO best practices. Meta tags, sitemaps, Open Graph, and semantic HTML included.",
        iconName: "Globe",
        badge: "Search Ready"
    },
    {
        title: "Easy Deployment",
        description: "Deploy to Vercel, Netlify, Cloudflare Workers, or any platform with one click.",
        iconName: "Cloud",
        badge: "Global CDN"
    }
];
---

<section id="features" class="features">
    <div class="content">
        <div class="header">
            <div class="badge">
                <Sparkles />
                <span>Features</span>
            </div>
            <h2 class="title">
                Everything You Need
            </h2>
            <p class="desc">
                Start building with a solid foundation. Modern tools, best practices, and beautiful design out of the box.
            </p>
        </div>

        <div class="grid">
            {features.map((feature) => (
                <Feature
                    title={feature.title}
                    description={feature.description}
                    iconName={feature.iconName}
                    badge={feature.badge}
                />
            ))}
        </div>

        <div class="cta">
            <p>Ready to start building?</p>
            <a
                href="https://docs.astro.build"
                target="_blank"
                rel="noopener noreferrer"
                class="cta-link"
            >
                <span>Explore the documentation</span>
                <ArrowRight />
            </a>
        </div>
    </div>
</section>

<style>
.features {
    padding-block: calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem));
    background-color: var(--color-surface-alt);
}

.content {
    max-width: var(--container-7xl, 80rem);
    margin-inline: auto;
    padding-inline: var(--space-md, 1rem);
}

.header {
    margin-bottom: var(--space-2xl, 3rem);
    text-align: center;
}

.badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm, 0.5rem);
    margin-bottom: var(--space-lg, 1.5rem);
    padding: var(--space-sm, 0.5rem) var(--space-md, 1rem);
    border-radius: var(--radius-full, 9999px);
    background-color: color-mix(in srgb, var(--color-primary) 10%, var(--color-surface));
    font-size: var(--text-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-primary);
}

.badge svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
}

.title {
    margin-bottom: var(--space-lg, 1.5rem);
    font-size: clamp(var(--text-3xl, 1.875rem), 5vw, var(--text-4xl, 2.25rem));
    font-weight: var(--font-weight-bold, 700);
    color: var(--color-content);
}

.desc {
    max-width: var(--container-3xl, 48rem);
    margin-inline: auto;
    font-size: var(--text-lg, 1.125rem);
    line-height: var(--leading-relaxed, 1.75);
    color: var(--color-content-light);
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    max-width: calc((16rem * 3) + (var(--space-lg, 1.5rem) * 2));
    margin-inline: auto;
    gap: var(--space-lg, 1.5rem);
}

.cta {
    margin-top: var(--space-2xl, 3rem);
    text-align: center;
}

.cta p {
    margin-bottom: var(--space-lg, 1.5rem);
    color: var(--color-content-light);
}

.cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm, 0.5rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-primary);
    text-decoration: none;
    cursor: pointer;
}

.cta-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 0.25rem;
}

.cta-link svg {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
}
</style>
