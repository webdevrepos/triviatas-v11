---
interface Props {
    bg?: 'surface' | 'surface-alt' | 'primary' | 'dark' | 'none';
    size?: 'sm' | 'md' | 'lg' | 'full';
    padding?: 'sm' | 'md' | 'lg' | 'none';
    title?: string;
    class?: string;
}
const { bg = 'none', size = 'lg', padding = 'lg', title, class: className } = Astro.props;
const bgMod = bg !== 'none' ? `is-bg-${bg}` : '';
const sizeMod = `size-${size}`;
const padMod = padding !== 'none' ? `is-pad-${padding}` : '';
---

<section class:list={["section", bgMod, sizeMod, padMod, className]}>
    <div class="container">
        {title && (<h2 class="title">{title}</h2>)}
        <slot />
    </div>
</section>

<style>
.section {
    display: block;
}

.is-bg-surface {
    background-color: var(--color-surface);
}

.is-bg-surface-alt {
    background-color: var(--color-surface-alt);
}

.is-bg-primary {
    background-color: var(--color-primary);
    color: #ffffff;
}

.is-bg-dark {
    background-color: #030712;
    color: #ffffff;
}

.is-pad-sm {
    --section-padding: var(--space-2xl, 3rem);
}

.is-pad-md {
    --section-padding: calc(var(--space-2xl, 3rem) + var(--space-md, 1rem));
}

.is-pad-lg {
    --section-padding: calc(var(--space-2xl, 3rem) + var(--space-xl, 2rem));
}

.is-pad-sm,
.is-pad-md,
.is-pad-lg {
    padding-block: var(--section-padding);
}

.container {
    margin-inline: auto;
    padding-inline: clamp(var(--space-md, 1rem), 4vw, var(--space-xl, 2rem));
}

.size-sm .container {
    max-width: var(--container-3xl, 48rem);
}

.size-md .container {
    max-width: var(--container-5xl, 64rem);
}

.size-lg .container {
    max-width: var(--container-7xl, 80rem);
}

.size-full .container {
    max-width: var(--container-full, 100%);
}

.title {
    margin-bottom: var(--space-xl, 2rem);
    font-size: var(--text-2xl, 1.5rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-content);
}

.is-bg-primary .title,
.is-bg-dark .title {
    color: #ffffff;
}
</style>
