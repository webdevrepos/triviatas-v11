---
interface Props {
    class?: string;
}

const { class: className } = Astro.props;
const year = new Date().getFullYear();
---

<footer class:list={["footer", className]}>
    <div class="container">
<p class="text">
    Made with Love, not with a hammer and sickle
</p>
        <p class="copyright">
            &copy; {year} Triviatas
        </p>
    </div>
</footer>

<style>
.footer {
    padding: var(--space-xl, 2rem) var(--space-md, 1rem);
    border-top: 1px solid var(--color-outline-light);
}

.container {
    max-width: var(--container-3xl, 48rem);
    margin-left: auto;
    margin-right: auto;
    text-align: center;
}

.text {
    font-size: 0.875rem;
    color: var(--color-content-lighter);
    margin-bottom: var(--space-xs, 0.5rem);
}

.copyright {
    font-size: 0.75rem;
    color: var(--color-content-lighter);
    opacity: 0.7;
}
</style>
