---
import { getNavigationPages, isActivePath } from '../../lib/navigation';
import { getCollection } from 'astro:content';

const currentPath = Astro.url.pathname;
const discoveredPages = await getNavigationPages();

const allPosts = await getCollection('blog');
const categories = [...new Set(allPosts.map(p => p.data.category))].sort();

const menuItems = [
    { id: 'home', type: 'home', label: 'Home', url: '/' },
    ...discoveredPages.map(page => ({
        id: 'page_' + page.slug,
        type: 'page' as const,
        label: page.title,
        url: page.url,
    })),
];
---

<nav class="desktop-nav" aria-label="Main navigation">
    {menuItems.map((item) => (
        <a
            href={item.url}
            target={item.type === 'custom' && item.url.startsWith('http') ? '_blank' : undefined}
            rel={item.type === 'custom' && item.url.startsWith('http') ? 'noopener noreferrer' : undefined}
            class:list={["nav-link", isActivePath(currentPath, item.url, item.url === '/') && "active"]}
        >
            {item.label}
        </a>
    ))}
    {categories.map((cat) => {
        const catSlug = cat.toLowerCase();
        return (
            <a
                href={`/category/${catSlug}`}
                class:list={["nav-link", isActivePath(currentPath, `/category/${catSlug}`) && "active"]}
            >
                {cat}
            </a>
        );
    })}
</nav>

<button type="button" class="menu-toggle" aria-label="Toggle menu" id="main-menu-toggle">
    <svg class="hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
    <svg class="close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
</button>

<div class="mobile-panel hidden" id="main-menu-mobile">
    <button type="button" class="backdrop" id="main-menu-overlay" aria-label="Close menu"></button>
    <nav class="mobile-nav" aria-label="Mobile navigation">
        <div class="mobile-header">
            <span>Menu</span>
            <button type="button" class="close-button" id="main-menu-close" aria-label="Close menu">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
        <div class="mobile-links">
            {menuItems.map((item) => (
                <a
                    href={item.url}
                    target={item.type === 'custom' && item.url.startsWith('http') ? '_blank' : undefined}
                    rel={item.type === 'custom' && item.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                    class:list={["mobile-link", isActivePath(currentPath, item.url, item.url === '/') && "active"]}
                >
                    {item.label}
                </a>
            ))}
            {categories.map((cat) => {
                const catSlug = cat.toLowerCase();
                return (
                    <a
                        href={`/category/${catSlug}`}
                        class:list={["mobile-link", isActivePath(currentPath, `/category/${catSlug}`) && "active"]}
                    >
                        {cat}
                    </a>
                );
            })}
        </div>
    </nav>
</div>

<script>
    const toggle = document.getElementById('main-menu-toggle');
    const mobile = document.getElementById('main-menu-mobile');
    const overlay = document.getElementById('main-menu-overlay');
    const close = document.getElementById('main-menu-close');
    const hamburgerIcon = toggle?.querySelector('.hamburger-icon');
    const closeIcon = toggle?.querySelector('.close-icon');

    function openMenu() {
        mobile?.classList.remove('hidden');
        hamburgerIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
        mobile?.classList.add('hidden');
        hamburgerIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        document.body.style.overflow = '';
    }

    toggle?.addEventListener('click', () => {
        if (mobile?.classList.contains('hidden')) {
            openMenu();
        } else {
            closeMenu();
        }
    });

    overlay?.addEventListener('click', closeMenu);
    close?.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !mobile?.classList.contains('hidden')) {
            closeMenu();
        }
    });
</script>

<style>
    .desktop-nav {
        display: none;
        align-items: center;
        gap: var(--space-xs);
    }

    .nav-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-xs);
        padding: var(--space-xs) var(--space-sm);
        border: 0;
        border-radius: var(--radius-md);
        font: inherit;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-content-light);
        text-decoration: none;
        background: transparent;
        cursor: pointer;
        transition: color 0.2s ease, background-color 0.2s ease;
    }

    .nav-link:hover,
    .active {
        color: var(--color-primary);
        background-color: color-mix(in srgb, var(--color-primary) 10%, transparent);
    }

    .menu-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: calc(var(--space-xl) + var(--space-xs));
        height: calc(var(--space-xl) + var(--space-xs));
        border: 0;
        border-radius: var(--radius-md);
        color: var(--color-content-light);
        background: transparent;
        cursor: pointer;
    }

    .menu-toggle svg,
    .close-button svg {
        width: var(--space-lg);
        height: var(--space-lg);
    }

    .mobile-panel {
        position: fixed;
        inset: 0;
        z-index: 50;
    }

    .backdrop {
        position: absolute;
        inset: 0;
        border: 0;
        background: rgb(0 0 0 / 0.4);
    }

    .mobile-nav {
        position: absolute;
        top: 0;
        right: 0;
        width: min(20rem, 85vw);
        height: 100%;
        background: var(--color-surface);
        box-shadow: var(--shadow-lg);
    }

    .mobile-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-md);
        border-bottom: 1px solid var(--color-outline);
    }

    .close-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: calc(var(--space-xl) + var(--space-xs));
        height: calc(var(--space-xl) + var(--space-xs));
        border: 0;
        border-radius: var(--radius-md);
        color: var(--color-content-light);
        background: transparent;
        cursor: pointer;
    }

    .mobile-links {
        padding-block: var(--space-xs);
    }

    .mobile-link {
        display: flex;
        width: 100%;
        align-items: center;
        padding: var(--space-sm) var(--space-md);
        border: 0;
        font: inherit;
        color: var(--color-content-light);
        text-decoration: none;
        background: transparent;
        cursor: pointer;
    }

    .mobile-link:hover {
        color: var(--color-content);
        background-color: var(--color-surface-alt);
    }

    @media (min-width: 768px) {
        .desktop-nav {
            display: flex;
        }

        .menu-toggle {
            display: none;
        }
    }
</style>
