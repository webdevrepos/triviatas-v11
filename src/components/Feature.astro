---
import FileText from '@lucide/astro/icons/file-text';
import Palette from '@lucide/astro/icons/palette';
import Zap from '@lucide/astro/icons/zap';
import LayoutGrid from '@lucide/astro/icons/layout-grid';
import Globe from '@lucide/astro/icons/globe';
import Cloud from '@lucide/astro/icons/cloud';

interface Props {
    title: string;
    description: string;
    iconName: string;
    badge?: string;
}

const { title, description, iconName, badge } = Astro.props;

const icons: Record<string, any> = {
    FileText,
    Palette,
    Zap,
    LayoutGrid,
    Globe,
    Cloud,
};

const IconComponent = icons[iconName] || Zap;
---

<article class="feature">
    <div class="card">
        <div class="icon-wrapper">
            <IconComponent class="icon" />
        </div>

        <h3 class="title">{title}</h3>
        <p class="desc">{description}</p>

        {badge && (
            <div class="badge">
                <span class="badge-dot"></span>
                <span class="badge-text">{badge}</span>
            </div>
        )}
    </div>
</article>

<style>
.feature {
    height: 100%;
}

.card {
    height: 100%;
    padding: var(--space-xl, 2rem);
    border-radius: var(--radius-xl, 0.75rem);
    background-color: var(--color-surface);
    border: 1px solid var(--color-outline);
}

.icon-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: var(--space-lg, 1.5rem);
    border-radius: var(--radius-xl, 0.75rem);
    background-color: color-mix(in srgb, var(--color-primary) 10%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, var(--color-outline));
}

.icon {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--color-primary);
}

.title {
    margin-bottom: var(--space-sm, 0.5rem);
    font-size: var(--text-xl, 1.25rem);
    font-weight: var(--font-weight-bold, 700);
    color: var(--color-content);
}

.desc {
    margin-bottom: var(--space-md, 1rem);
    line-height: var(--leading-relaxed, 1.75);
    color: var(--color-content-light);
}

.badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs, 0.25rem);
    padding: var(--space-xs, 0.25rem) var(--space-sm, 0.5rem);
    border-radius: var(--radius-full, 9999px);
    background-color: color-mix(in srgb, var(--color-primary) 8%, var(--color-surface));
}

.badge-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 9999px;
    background-color: var(--color-primary);
}

.badge-text {
    font-size: var(--text-sm, 0.875rem);
    font-weight: var(--font-weight-medium, 500);
    color: var(--color-primary);
}
</style>
